@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Erişim Reddedildi</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            overflow: hidden;
        }

        .container {
            text-align: center;
            padding: 3rem;
            position: relative;
            z-index: 1;
        }

        .error-code {
            font-size: 10rem;
            font-weight: 900;
            line-height: 1;
            background: linear-gradient(135deg, #e74c3c, #c0392b);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-shadow: none;
            animation: pulse 2s ease-in-out infinite;
        }

  
            opacity: 1;
        }

        50% {
            opacity: 0.7;
        }

        }

        .lock-icon {
            font-size: 5rem;
            margin: 1rem 0;
            display: block;
            animation: shake 3s ease-in-out infinite;
        }

   
            transform: rotate(0deg);
        }

        10%, 30%, 50%, 70%, 90% {
            transform: rotate(-5deg);
        }

        20%, 40%, 60%, 80% {
            transform: rotate(5deg);
        }

        }

        h3 {
            color: #ecf0f1;
            font-size: 1.6rem;
            margin: 1rem 0 0.5rem;
            font-weight: 600;
        }

        p {
            color: #95a5a6;
            font-size: 1rem;
            margin-bottom: 2rem;
        }

        .btn-home {
            display: inline-block;
            padding: 0.8rem 2rem;
            background: linear-gradient(135deg, #e74c3c, #c0392b);
            color: #fff;
            text-decoration: none;
            border-radius: 50px;
            font-size: 1rem;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(231, 76, 60, 0.4);
        }

            .btn-home:hover {
                transform: translateY(-3px);
                box-shadow: 0 8px 25px rgba(231, 76, 60, 0.6);
                color: #fff;
            }

        /* Arka plan dekoratif daireler */
        .circle {
            position: fixed;
            border-radius: 50%;
            opacity: 0.05;
            background: #e74c3c;
        }

        .circle-1 {
            width: 500px;
            height: 500px;
            top: -150px;
            left: -150px;
        }

        .circle-2 {
            width: 300px;
            height: 300px;
            bottom: -100px;
            right: -100px;
        }

        .circle-3 {
            width: 200px;
            height: 200px;
            top: 50%;
            right: 10%;
            opacity: 0.03;
        }
    </style>
</head>
<body>
    <div class="circle circle-1"></div>
    <div class="circle circle-2"></div>
    <div class="circle circle-3"></div>

    <div class="container">
        <span class="lock-icon">🔒</span>
        <div class="error-code">403</div>
        <h3>Erişim Reddedildi</h3>
        <p>Bu sayfaya erişim yetkiniz bulunmamaktadır.<br>Admin paneline erişmek için Admin yetkisine sahip olmanız gerekmektedir.</p>
        <a href="/Home/Index" class="btn-home">Ana Sayfaya Dön</a>
    </div>
</body>
</html>