@model UserRegisterViewModel
@{
	Layout = null;
}
<!DOCTYPE html>
<html>
<head>
	<meta charset="utf-8">
	<title>Traversal Misafir Kayıt Ekranı</title>
	<meta name="viewport" content="width=device-width, initial-scale=1.0">

	<!-- LINEARICONS -->
	<link rel="stylesheet" href="~/colorlib-regform-26/fonts/linearicons/style.css">

	<link rel="stylesheet" type="text/css" href="~/Login_v1/vendor/bootstrap/css/bootstrap.min.css">

	<link rel="stylesheet" type="text/css" href="~/Login_v1/fonts/font-awesome-4.7.0/css/font-awesome.min.css">
	<link rel="stylesheet" type="text/css" href="~/Login_v1/vendor/animate/animate.css">
	<link rel="stylesheet" type="text/css" href="~/Login_v1/vendor/css-hamburgers/hamburgers.min.css">
	<link rel="stylesheet" type="text/css" href="~/Login_v1/vendor/select2/select2.min.css">

	<link rel="stylesheet" type="text/css" href="~/Login_v1/css/util.css">
	<link rel="stylesheet" type="text/css" href="~/Login_v1/css/main.css">
	<link rel="stylesheet" href="~/colorlib-regform-26/css/style.css">
	<style type="text/css">
		.text-danger{ color: red;font-weight: bold;}
	</style>
</head>

<body>

	<div class="wrapper">
		<div class="inner">
			<img src="~/colorlib-regform-26/images/image-1.png" alt="" class="image-1">
			<form action="" method="post">
				<h3>Yeni Hesap?</h3>
				<div class="form-holder">
					<span class="lnr lnr-user"></span>
					<input type="text" class="form-control" placeholder="Adınız" name="Name">
					
				</div>
				<span asp-validation-for="Name" class="text-danger"></span>
				<div class="form-holder">
					<span class="lnr lnr-user"></span>
					<input type="text" class="form-control" placeholder="Soyadınız" name="Surname">
					
				</div>
				<span asp-validation-for="Surname" class="text-danger"></span>
				<div class="form-holder">
					<span class="lnr lnr-user"></span>
					<input type="text" class="form-control" placeholder="Kullanıcı Adınız" name="Username">
					
				</div>
				<span asp-validation-for="Username" class="text-danger"></span>
				<div class="form-holder">
					<span class="lnr lnr-envelope"></span>
					<input type="text" class="form-control" placeholder="Mail Adresiniz" name="Email">
					
				</div>
				<span asp-validation-for="Email" class="text-danger"></span>
				<div class="form-holder">
					<span class="lnr lnr-phone-handset"></span>
					<input type="text" class="form-control" placeholder="Telefon Numaranız" name="Phone">
					
				</div>
				<span asp-validation-for="Phone" class="text-danger"></span>
				<div class="form-holder">
					<span class="lnr lnr-lock"></span>
					<input type="password" class="form-control" placeholder="Şifreniz" name="Password">
					
				</div>
				<span asp-validation-for="Password" class="text-danger"></span>
				<div class="form-holder">
					<span class="lnr lnr-lock"></span>
					<input type="password" class="form-control" placeholder="Şifre tekrar" name="ConfirmPassword">
					
				</div>
				<span asp-validation-for="ConfirmPassword" class="text-danger"></span>
				<div class="text-danger" asp-validation-summary="ModelOnly"></div>
				<button>
					<span>Kayıt Ol</span>
				</button>
				<div class="text-center p-t-136">
					<a class="txt2" href="/Login/SignIn">
						Giriş Yap
						<i class="fa fa-long-arrow-right m-l-5" aria-hidden="true"></i>
					</a>
				</div>
			</form>
			<img src="~/colorlib-regform-26/images/image-2.png" alt="" class="image-2">
		</div>

	</div>

	<script src="~/colorlib-regform-26/js/jquery-3.3.1.min.js"></script>
	<script src="~/colorlib-regform-26/js/main.js"></script>
	<script src="~/Login_v1/vendor/jquery/jquery-3.2.1.min.js"></script>

	<script src="~/Login_v1/vendor/bootstrap/js/popper.js"></script>
	<script src="~/Login_v1/vendor/bootstrap/js/bootstrap.min.js"></script>

	<script src="~/Login_v1/vendor/select2/select2.min.js"></script>
	<script src="~/Login_v1/vendor/tilt/tilt.jquery.min.js"></script>
	<script>
		$('.js-tilt').tilt({
			scale: 1.1
		})
	</script>

	<script src="~/Login_v1/js/main.js"></script>
</body>
</html>