@model List<Destination>
<div class="col-12 mt-4">
    <div class="card mb-4">
        <div class="card-header pb-0 p-3">
            <h6 class="mb-1">Son Rotalar</h6>
            <p class="text-sm">Traversal Şirketinin En Son Eklenen Seyahat Rotaları</p>
        </div>
        <div class="card-body p-3">
            <div class="row">
                @foreach (var item in Model)
                {
                    <div class="col-xl-3 col-md-6 mb-xl-0 mb-4">
                        <div class="card card-blog card-plain">
                            <div class="position-relative">
                                <a class="d-block shadow-xl border-radius-xl">
                                    @if (!string.IsNullOrEmpty(item.DestinationImage))
                                    {
                                        <img src="~/destinationImages/@item.DestinationImage"
                                             style="width:400px; height:200px; object-fit:cover;"
                                             alt="@item.DestinationCity"
                                             class="img-fluid shadow border-radius-xl">
                                    }
                                </a>
                            </div>
                            <div class="card-body px-1 pb-0">
                                <p class="text-gradient text-dark mb-2 text-sm">@item.DestinationDayNight - @item.DestinationPrice ₺</p>
                                <a href="javascript:;">
                                    <h5>@item.DestinationCity</h5>
                                </a>
                                <p class="mb-4 text-sm">
                                    @if (!string.IsNullOrEmpty(item.Details2))
                                    {
                                        @(item.Details2.Length > 100 ? item.Details2.Substring(0, 100) + "..." : item.Details2)
                                    }
                                </p>
                                <div class="d-flex align-items-center justify-content-between">
                                    <a href="/Destination/DestinationDetails/@item.DestinationID" class="btn btn-outline-primary btn-sm mb-0">Tur Detayları</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>