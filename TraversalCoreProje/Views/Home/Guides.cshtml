@model List<Guide>

@{
    ViewData["Title"] = "Rehberlerimiz";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="w3l-team" id="team">
    <div class="team-block py-5">
        <div class="container py-lg-5">
            <div class="title-content text-center mb-lg-3 mb-4">
                <h6 class="sub-title">Ekibimiz</h6>
                <h3 class="hny-title">Rehberlerimizle Tanışın</h3>
            </div>
            <div class="row">
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model.Where(x => x.GuideStatus == true))
                    {
                        <div class="col-lg-3 col-6 mt-lg-5 mt-4">
                            <div class="box16">
                                <a href="#url">
                                    @if (!string.IsNullOrEmpty(item.Image))
                                    {
                                        <img src="~/guideImages/@item.Image" alt="@item.Name" class="img-fluid" />
                                    }
                                    else
                                    {
                                        <img src="~/assets/images/team1.jpg" alt="@item.Name" class="img-fluid" />
                                    }
                                </a>
                                <div class="box-content">
                                    <h3 class="title"><a href="#url">@item.Name</a></h3>
                                    <span class="post">@item.Description</span>
                                    <ul class="social">
                                        @if (!string.IsNullOrEmpty(item.TwitterUrl))
                                        {
                                            <li>
                                                <a href="@item.TwitterUrl" target="_blank" class="twitter">
                                                    <span class="fa fa-twitter"></span>
                                                </a>
                                            </li>
                                        }
                                        @if (!string.IsNullOrEmpty(item.InstagramUrl))
                                        {
                                            <li>
                                                <a href="@item.InstagramUrl" target="_blank" class="facebook">
                                                    <span class="fa fa-instagram"></span>
                                                </a>
                                            </li>
                                        }
                                    </ul>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center">
                        <p>Henüz rehber eklenmemiş.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</section>
<!-- //team -->