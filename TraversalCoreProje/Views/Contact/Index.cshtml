@model Contact
@{
    ViewData["Title"] = "İletişim";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<section class="w3l-about-breadcrumb text-left">
    <div class="breadcrumb-bg breadcrumb-bg-about py-sm-5 py-4">
        <div class="container py-2">
            <h2 class="title">İletişim</h2>
            <ul class="breadcrumbs-custom-path mt-2">
                <li><a href="/Home/Index">Ana Sayfa</a></li>
                <li class="active"><span class="fa fa-arrow-right mx-2" aria-hidden="true"></span> İletişim </li>
            </ul>
        </div>
    </div>
</section>
<!-- //about breadcrumb -->
<!-- contact-form -->
<section class="w3l-contact" id="contact">
    <div class="contact-infubd py-5">
        <div class="container py-lg-3">
            <div class="contact-grids row">
                <div class="col-lg-6 contact-left">
                    <div class="partners">
                        <div class="cont-details">
                            <h5>Bize Ulaşın</h5>
                            <p class="mt-3 mb-4">
                                @Model?.Description
                            </p>
                        </div>
                        <div class="hours">
                            @if (Model != null)
                            {
                                <h6 class="mt-4">E-posta:</h6>
                                <p>
                                    <a href="mailto:@Model.Mail">@Model.Mail</a>
                                </p>
                                <h6 class="mt-4">Adresimiz:</h6>
                                <p>@Model.Address</p>
                                <h6 class="mt-4">Telefon:</h6>
                                <p class="margin-top"><a href="tel:@Model.Phone">@Model.Phone</a></p>
                            }
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 mt-lg-0 mt-5 contact-right">
                    <form asp-controller="Contact" asp-action="ContactForm" method="post" class="signin-form">
                        <div class="input-grids">
                            <div class="form-group">
                                <input type="text" name="Name" placeholder="Adınız*" class="contact-input" required />
                            </div>
                            <div class="form-group">
                                <input type="email" name="Mail" placeholder="E-posta Adresiniz*" class="contact-input" required />
                            </div>
                            <div class="form-group">
                                <input type="text" name="Subject" placeholder="Konu*" class="contact-input" required />
                            </div>
                        </div>
                        <div class="form-group">
                            <textarea name="MessageBody" placeholder="Mesajınızı buraya yazınız*" required></textarea>
                        </div>
                        <div class="text-right">
                            <button class="btn btn-style btn-primary">Mesaj Gönder</button>
                        </div>
                    </form>
                </div>
            </div>

            @if (Model != null && !string.IsNullOrEmpty(Model.MapLocation))
            {
                <div class="map mt-5 pt-md-5">
                    <h5>Konum</h5>
                    <iframe src="@Model.MapLocation" style="border:0" allowfullscreen=""></iframe>
                </div>
            }
        </div>
    </div>
</section>
<!-- /contact-form -->