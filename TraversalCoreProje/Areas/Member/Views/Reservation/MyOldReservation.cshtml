@model List<Reservation>
@{
    ViewData["Title"] = "MyOldReservation";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}


<div class="container-fluid py-4">
    <div class="row">
        <div class="col-12">
            <div class="card my-4">
                <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
                    <div class="bg-gradient-dark shadow-dark border-radius-lg pt-4 pb-3">
                        <h6 class="text-white text-capitalize ps-3">Eski Rezervasyonlarım</h6>
                    </div>
                </div>
                <div class="card-body px-0 pb-2">
                    <div class="table-responsive p-0">
                        <table class="table align-items-center mb-0">
                            <thead>
                                <tr>
                                    <th class="text-uppercase text-secondary text-xs font-weight-bolder opacity-7 ps-2">Rota</th>
                                    <th class="text-uppercase text-secondary text-xs font-weight-bolder opacity-7">Kişi Sayısı</th>
                                    <th class="text-uppercase text-secondary text-xs font-weight-bolder opacity-7">Rezervasyon Tarihi</th>
                                    <th class="text-uppercase text-secondary text-xs font-weight-bolder opacity-7">Açıklama</th>
                                    <th class="text-uppercase text-secondary text-xs font-weight-bolder opacity-7 text-center">Durum</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex px-2 py-1">
                                                    <div class="d-flex flex-column justify-content-center">
                                                        <h6 class="mb-0 text-sm">@item.Destination.DestinationCity</h6>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <p class="text-sm font-weight-bold mb-0">@item.PersonCount</p>
                                            </td>
                                            <td>
                                                <p class="text-sm font-weight-bold mb-0">@item.ReservationDate.ToString("dd.MM.yyyy")</p>
                                            </td>
                                            <td>
                                                <p class="text-sm mb-0">@item.Description</p>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge badge-sm bg-gradient-success">@item.Status</span>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-4">
                                            <p class="text-sm mb-0">Geçmiş rezervasyonunuz bulunmamaktadır.</p>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>