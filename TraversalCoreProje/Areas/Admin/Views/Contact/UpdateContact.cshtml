@model Contact
@{
    ViewData["Title"] = "İletişim Bilgilerini Güncelle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="content-wrapper">
    <div class="container-xxl flex-grow-1 container-p-y">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">İletişim Bilgilerini Düzenle</h5>
            </div>
            <div class="card-body">
                <form asp-area="Admin" asp-controller="Contact" asp-action="UpdateContact" method="post">

                    <input type="hidden" asp-for="ContactID" />
                    <input type="hidden" asp-for="ContactStatus" />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-uppercase" asp-for="Mail">E-Posta Adresi</label>
                            <input type="email" class="form-control" asp-for="Mail" placeholder="Örn: info@firma.com" required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold text-uppercase" asp-for="Phone">Telefon Numarası</label>
                            <input type="text" class="form-control" asp-for="Phone" placeholder="Örn: +90 212 XXX XX XX" required />
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-bold text-uppercase" asp-for="Address">Adres</label>
                            <textarea class="form-control" asp-for="Address" rows="3" placeholder="Açık adres yazınız..." required></textarea>
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-bold text-uppercase" asp-for="Description">Açıklama (Ön Söz)</label>
                            <textarea class="form-control" asp-for="Description" rows="2" placeholder="İletişim sayfası için kısa bir açıklama yazısı..."></textarea>
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-bold text-uppercase" asp-for="MapLocation">Harita Konumu (Google Maps Iframe SRC Değeri)</label>
                            <input type="text" class="form-control" asp-for="MapLocation" placeholder="https://www.google.com/maps/embed?pb=..." required />
                        </div>

                        @if (!string.IsNullOrEmpty(Model?.MapLocation))
                        {
                            <div class="col-12">
                                <label class="form-label fw-bold text-uppercase text-muted">Mevcut Harita Önizlemesi</label>
                                <div class="mt-1">
                                    <iframe src="@Model.MapLocation"
                                            width="100%"
                                            height="250"
                                            style="border:0; border-radius:8px;"
                                            allowfullscreen=""
                                            loading="lazy">
                                    </iframe>
                                </div>
                            </div>
                        }

                        <div class="col-12 text-end mt-4">
                            <a asp-action="Index" class="btn btn-secondary me-2">İptal</a>
                            <button type="submit" class="btn btn-primary">Değişiklikleri Kaydet</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>