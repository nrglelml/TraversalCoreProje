@model Contact
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="content-wrapper">
    <div class="container-xxl flex-grow-1 container-p-y">

       

        <div class="card">
            <div class="card-body">

                @if (Model == null || !Model.ContactStatus == true)
                {
                    <div class="text-center py-5">
                        <i class="bx bx-info-circle bx-lg text-warning mb-3"></i>
                        <h5>İletişim bilgisi bulunmamaktadır.</h5>
                        <a href="/Admin/Contact/AddContact" class="btn btn-primary mt-2">Hemen Oluşturun</a>
                    </div>
                }
                else
                {
                    if (Model.ContactStatus == true)
                    {
                        <div class="card border mb-3">
                            <div class="card-body">
                                <div class="row g-3">

                                    <div class="col-md-6">
                                        <label class="text-muted text-xs fw-bold text-uppercase">Mail</label>
                                        <p class="mb-0"><a href="mailto:@Model.Mail">@Model.Mail</a></p>
                                    </div>

                                    <div class="col-md-6">
                                        <label class="text-muted text-xs fw-bold text-uppercase">Telefon</label>
                                        <p class="mb-0"><a href="tel:@Model.Phone">@Model.Phone</a></p>
                                    </div>

                                    <div class="col-md-6">
                                        <label class="text-muted text-xs fw-bold text-uppercase">Adres</label>
                                        <p class="mb-0">@Model.Address</p>
                                    </div>

                                    <div class="col-md-6">
                                        <label class="text-muted text-xs fw-bold text-uppercase">Açıklama</label>
                                        <p class="mb-0">@Model.Description</p>
                                    </div>

                                    @if (!string.IsNullOrEmpty(Model.MapLocation))
                                    {
                                        <div class="col-12">
                                            <label class="text-muted text-xs fw-bold text-uppercase">Harita</label>
                                            <div class="mt-2">
                                                <iframe src="@Model.MapLocation"
                                                        width="100%"
                                                        height="250"
                                                        style="border:0; border-radius:8px;"
                                                        allowfullscreen=""
                                                        loading="lazy">
                                                </iframe>
                                            </div>
                                        </div>
                                    }

                                    <div class="col-12 d-flex gap-2 mt-2">
                                        <a href="/Admin/Contact/UpdateContact/@Model.ContactID" class="btn btn-outline-warning btn-sm">
                                            <i class="bx bx-edit me-1"></i> Güncelle
                                        </a>
                                        <a href="/Admin/Contact/DeleteContact/@Model.ContactID"
                                           class="btn btn-outline-danger btn-sm"
                                           onclick="return confirm('Bu iletişim bilgisini silmek istediğinize emin misiniz?');">
                                            <i class="bx bx-trash me-1"></i> Sil
                                        </a>
                                    </div>

                                </div>
                            </div>
                        </div>
                    }
                }

            </div>
        </div>

    </div>
</div>