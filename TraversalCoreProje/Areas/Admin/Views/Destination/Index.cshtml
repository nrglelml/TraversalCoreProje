@model List<Destination>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<h1>Gezi Rotaları</h1>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Oluşturan</th>
            <th>#</th>
            <th>Şehir</th>
            <th>Fiyat</th>
            <th>Süre</th>
            <th>Kapasite</th>
            <th>Durum</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @if (item.GuideID != null && item.Guide != null && !string.IsNullOrEmpty(item.Guide.Image))
                    {
                        <div style="width:40px; height:40px; border-radius:50%; overflow:hidden;"
                             data-bs-toggle="tooltip"
                             title="@item.Guide.Name">
                            <img src="~/guideImages/@item.Guide.Image"
                                 style="width:100%; height:100%; object-fit:cover; display:block;" />
                        </div>
                    }
                    else
                    {
                        <div style="width:40px; height:40px; border-radius:50%; overflow:hidden;"
                             data-bs-toggle="tooltip"
                             title="Admin">
                            <img src="~/assets/img/admin-default.png"
                                 style="width:100%; height:100%; object-fit:cover; display:block;" />
                        </div>
                    }
                </td>
                <td>
                    <ul class="list-unstyled users-list m-0 avatar-group d-flex align-items-center">
                        <li data-bs-toggle="tooltip"
                            data-popup="tooltip-custom"
                            data-bs-placement="top"
                            class="avatar avatar-xs pull-up"
                            title="@item.DestinationCity">
                            <img src="~/destinationImages/@item.DestinationImage" class="rounded-circle" />
                        </li>
                    </ul>
                </td>
                <td>
                    <i class="fab fa-angular fa-lg text-danger me-3"></i> <strong>@item.DestinationCity</strong>
                </td>
                <td>@item.DestinationPrice</td>
                <td>@item.DestinationDayNight</td>
                <td>@item.DestinationCapacity</td>
                @if (item.DestinationStatus == true)
                {
                    <td><span class="badge bg-label-primary me-1">@item.DestinationStatus</span></td>
                }
                else
                {
                    <td><span class="badge bg-label-danger me-1">@item.DestinationStatus</span></td>
                }
                <td>
                    <a class="dropdown-item" href="/Destination/DestinationDetails/@item.DestinationID"><i class="bx bx-show me-1"></i> Sitede Gör</a>
                    <a class="dropdown-item" href="/Admin/Destination/Details/@item.DestinationID"><i class="bx bx-edit-alt me-1"></i> Detaylar</a>
                </td>
            </tr>
        }
    </tbody>
</table>
<a class="btn btn-outline-primary" href="/Admin/Destination/AddDestination">Yeni Gezi Rotası Ekle</a>