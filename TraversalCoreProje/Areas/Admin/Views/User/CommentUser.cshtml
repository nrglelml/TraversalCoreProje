@model List<Comment>
@{
    ViewData["Title"] = "Kullanıcı Yorumları";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int count = 0;
}

<div class="content-wrapper">
    <div class="container-xxl flex-grow-1 container-p-y">

        <h4 class="mb-4">Kullanıcı Yorumları</h4>

        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Yapılan Yorumlar</h5>
            </div>
            <div class="card-body">

                @if (Model == null || !Model.Any())
                {
                    <div class="text-center py-5">
                        <p class="mb-0">Bu kullanıcıya ait yorum bulunmamaktadır.</p>
                    </div>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        count++;
                        <div class="card mb-3 border">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">

                                    <div class="d-flex align-items-center">
                                        <div style="width:42px; height:42px; border-radius:50%; overflow:hidden;" class="me-3 flex-shrink-0">
                                            @if (item.AppUser != null && !string.IsNullOrEmpty(item.AppUser.ImageURL))
                                            {
                                                <img src="~/userImages/@item.AppUser.ImageURL"
                                                     style="width:100%; height:100%; object-fit:cover; display:block;" />
                                            }
                                            else
                                            {
                                                <div class="bg-primary text-white d-flex align-items-center justify-content-center"
                                                     style="width:100%; height:100%; font-size:1rem;">
                                                    @(item.AppUser?.Name?.Substring(0, 1).ToUpper())
                                                </div>
                                            }
                                        </div>
                                        <div>
                                            <h6 class="mb-0">@item.AppUser?.Name @item.AppUser?.Surname</h6>
                                            <small class="text-muted">@item.Destination?.DestinationCity rotası için</small>
                                        </div>
                                    </div>

                                    <div class="text-end">
                                        @if (item.State == true)
                                        {
                                            <span class="badge bg-label-success mb-1">Onaylı</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-label-warning mb-1">Onay Bekliyor</span>
                                        }
                                        <div><small class="text-muted">@item.Date.ToString("dd.MM.yyyy HH:mm")</small></div>
                                    </div>

                                </div>

                                <p class="mt-3 mb-3">@item.Content</p>

                                <a href="/Admin/Comment/DeleteComment/@item.CommentID"
                                   class="btn btn-outline-danger btn-sm"
                                   onclick="return confirm('Bu yorumu silmek istediğinize emin misiniz?');">
                                    <i class="bx bx-trash me-1"></i> Sil
                                </a>
                            </div>
                        </div>
                    }
                }

            </div>
        </div>

    </div>
</div>