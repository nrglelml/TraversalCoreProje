@model List<About2>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="content-wrapper">
    <div class="container-xxl flex-grow-1 container-p-y">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="mb-0">İletişim Bilgileri</h4>
            <a href="/Admin/About2/AddAbout" class="btn btn-primary">
                <i class="bx bx-plus me-1"></i> Yeni Ekle
            </a>
        </div>

        <div class="card">
            <div class="card-body">

                @if (Model == null || !Model.Any(x=>x.About2Status==true))
                {
                    <div class="text-center py-5">
                        <i class="bx bx-info-circle bx-lg text-warning mb-3"></i>
                        <h5>İletişim bilgisi bulunmamaktadır.</h5>
                        <a href="/Admin/About2/AddAbout" class="btn btn-primary mt-2">Hemen Oluşturun</a>
                    </div>
                }
                else
                {
                    
                        <table class="table table-bordered">
                            <tr>
                                <th>#</th>
                                <th>Görsel</th>
                                <th>Başlık</th>
                                <th>Açıklama</th>
                                <th>İşlemler</th>
                            </tr>

                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.About2ID</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.Image))
                                    {
                                        <img src="~/aboutImages/@item.Image" height="50" width="50" style="object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <div class="d-flex align-items-center justify-content-center rounded bg-secondary text-white" style="width:50px; height:50px; font-size:10px;">
                                            Resim Yok
                                        </div>
                                    }
                                </td>
                                <td>@item.Title</td>
                                <td>@item.Description</td>
   
                                <td>
                                    <a href="/Admin/About2/UpdateAbout/@item.About2ID" class="btn btn-outline-success">Düzenle</a>
                                    <a href="/Admin/About2/DeleteAbout/@item.About2ID" class="btn btn-outline-danger">Sil</a>
                                </td>
                            </tr>
                        }
                        </table>
                    
                }

            </div>
        </div>

    </div>
</div>