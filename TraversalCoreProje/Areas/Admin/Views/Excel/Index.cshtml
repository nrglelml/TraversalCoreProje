@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


<div class="content-wrapper">
    <div class="container-xxl flex-grow-1 container-p-y">

        <h4 class="mb-4">Raporlar</h4>

        <div class="row">
            <!-- Excel Raporları -->
            <div class="col-md-6 mb-4">
                <div class="card h-100">
                    <div class="card-header d-flex align-items-center">
                        <i class="bx bx-spreadsheet bx-sm text-success me-2"></i>
                        <h5 class="mb-0">Excel Raporları</h5>
                    </div>
                    <div class="card-body d-flex flex-column gap-3">
                        <a href="/Admin/Excel/StaticExcelReport/" class="btn btn-outline-success d-flex align-items-center justify-content-between">
                            <span><i class="bx bx-download me-2"></i>Statik Excel Raporu</span>
                            <i class="bx bx-chevron-right"></i>
                        </a>
                        <a href="/Admin/Excel/DestinationExcelReport/" class="btn btn-outline-success d-flex align-items-center justify-content-between">
                            <span><i class="bx bx-download me-2"></i>Tur Rotaları Excel Raporu</span>
                            <i class="bx bx-chevron-right"></i>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Pdf Raporları -->
            <div class="col-md-6 mb-4">
                <div class="card h-100">
                    <div class="card-header d-flex align-items-center">
                        <i class="bx bxs-file-pdf bx-sm text-danger me-2"></i>
                        <h5 class="mb-0">Pdf Raporları</h5>
                    </div>
                    <div class="card-body d-flex flex-column gap-3">
                        <a href="/Admin/PdfReport/StaticPdfReport" class="btn btn-outline-danger d-flex align-items-center justify-content-between">
                            <span><i class="bx bx-download me-2"></i>Statik Pdf Raporu</span>
                            <i class="bx bx-chevron-right"></i>
                        </a>
                        <a href="/Admin/PdfReport/StaticCustomerReport" class="btn btn-outline-danger d-flex align-items-center justify-content-between">
                            <span><i class="bx bx-download me-2"></i>Statik Misafir Raporu</span>
                            <i class="bx bx-chevron-right"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>